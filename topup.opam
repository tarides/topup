# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
version: "0.1.0"
synopsis: "An OCaml toplevel exposed as an MCP server"
description:
  "topup wraps the OCaml toplevel as a Model Context Protocol server, letting an LLM keep typed working memory across conversation turns. Bindings persist between eval calls; the model carries only names and types in its context."
maintainer: ["Cuihtlauac ALVARADO <cuihtlauac@tarides.com>"]
authors: ["Cuihtlauac ALVARADO <cuihtlauac@tarides.com>"]
license: "ISC"
homepage: "https://github.com/tarides/topup"
bug-reports: "https://github.com/tarides/topup/issues"
depends: [
  "dune" {>= "3.6"}
  "ocaml" {>= "5.1"}
  "ocamlfind"
  "yojson"
  "base64"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/tarides/topup.git"
